# Django Secret Key - Generate a new one!
# Run this in Python: from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())
SECRET_KEY=your-secret-key-here

# Set to True only in development
DEBUG=False

# Your Railway domain
ALLOWED_HOSTS=yourdomain.railway.app,www.yourdomain.railway.app

# Email Configuration (Gmail)
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# Database Configuration (only if you upgrade to PostgreSQL later)
# DATABASE_URL=postgresql://user:password@host:port/dbname
