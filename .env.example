# ============================================================================
# DJANGO CORE SETTINGS
# ============================================================================

# Generate a new SECRET_KEY using:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-super-secret-key-change-in-production

# Never set to True in production
DEBUG=False

# Your production domain(s) - comma separated
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,railway.app

# CORS allowed origins - comma separated
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Option 1: PostgreSQL (Recommended for production)
# Format: postgresql://username:password@hostname:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/obdms_db

# ============================================================================
# CACHING & SESSION
# ============================================================================

# Redis URL for caching (Optional)
REDIS_URL=redis://:password@localhost:6379/0

# ============================================================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ============================================================================

# Gmail: Use App Password, not your main password
# 1. Enable 2FA on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate an "App Password" for Mail
# 4. Use that password here

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password

# ============================================================================
# SECURITY - HTTPS/SSL
# ============================================================================

# Enable HTTPS redirect (set to True for production)
SECURE_SSL_REDIRECT=True

# Session security settings
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# HSTS settings
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# ============================================================================
# ERROR TRACKING (Sentry - Optional)
# ============================================================================

# Get your DSN from https://sentry.io
# SENTRY_DSN=https://your-key@sentry.io/your-project-id

# ============================================================================
# DEPLOYMENT PLATFORM
# ============================================================================

ENVIRONMENT=production
